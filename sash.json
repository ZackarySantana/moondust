{
    "name": "moondust",
    "goMain": ".",
    "frontend": {
        "dir": "packages",
        "install": "bun install",
        "build": "bun run --filter @moondust/studio build",
        "dev": "bun run --filter @moondust/studio dev"
    },
    "bindings": {
        "apiImportPath": "moondust/internal/v2/sashapi",
        "type": "API",
        "goBindingsDir": "sashbindings",
        "tsBindingsDir": "packages/studio/src/bindings",
        "mountPath": "/api/sash",
        "devListenAddr": "127.0.0.1:9350",
        "devAPIBaseURL": "http://127.0.0.1:9350"
    }
}
